import pandas as pd
import matplotlib.pyplot as plt

votes = {
    "Alice": 0,
    "Bob": 0,
    "Charlie": 0
}

voted_users = []

while True:

    print("\n===== ONLINE VOTING SYSTEM =====")
    print("1. Vote")
    print("2. View Results")
    print("3. Exit")

    choice = input("Enter Choice: ")

    if choice == "1":

        voter = input("Enter Voter ID: ")

        if voter in voted_users:
            print("You already voted!")
            continue

        print("\nCandidates")
        print("1. Alice")
        print("2. Bob")
        print("3. Charlie")

        vote = int(input("Select Candidate: "))

        if vote == 1:
            votes["Alice"] += 1

        elif vote == 2:
            votes["Bob"] += 1

        elif vote == 3:
            votes["Charlie"] += 1

        else:
            print("Invalid Candidate")
            continue

        voted_users.append(voter)

        print("Vote Cast Successfully!")

    elif choice == "2":

        print("\nResults")

        for candidate, count in votes.items():
            print(candidate, ":", count)

    elif choice == "3":
        break

    else:
        print("Invalid Choice")

df = pd.DataFrame(
    list(votes.items()),
    columns=["Candidate", "Votes"]
)

df

plt.figure(figsize=(6,4))

plt.bar(
    df["Candidate"],
    df["Votes"]
)

plt.title("Election Results")
plt.xlabel("Candidates")
plt.ylabel("Votes")

plt.show()

df.to_csv("voting_results.csv", index=False)

print("Results Saved Successfully")
